{
    "version": 2,
    "builds": [
        {
            "src": "api/news.js",
            "use": "@vercel/node"
        },
        {
            "src": "api/sync.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/api/news",
            "dest": "/api/news.js"
        },
        {
            "src": "/api/sync",
            "dest": "/api/sync.js"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}